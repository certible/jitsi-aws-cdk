{
  "name": "@certible/jitsi-aws-cdk",
  "version": "1.1.0",
  "description": "TypeScript CDK stack constructs for deploying CloudWatch Widgets for Jitsi Meets.",
  "author": "Certible <oberreiter@certible.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/certible/jitsi-aws-cdk/jitsi-aws-cdk.git"
  },
  "bugs": {
    "url": "https://github.com/certible/jitsi-aws-cdk/issues"
  },
  "keywords": [
    "aws",
    "cdk",
    "jitsi"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "test": "node ./test/index.test.mjs",
    "pretest": "pnpm run build",
    "build": "tsdown",
    "lint": "oxlint lib test tsdown.config.ts",
    "lint:fix": "oxlint --fix lib test tsdown.config.ts",
    "format": "oxfmt --check lib test tsdown.config.ts",
    "format:fix": "oxfmt --write lib test tsdown.config.ts"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.5.0"
  },
  "devDependencies": {
    "constructs": "^10.6.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0"
  },
  "packageManager": "pnpm@11.4.0",
  "type": "module"
}
